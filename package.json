{
  "name": "ai-devops-demo",
  "version": "1.0.0",
  "description": "Demo app for AI-powered CI/CD pipeline with n8n",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --coverage --verbose",
    "test:unit": "jest tests/calculator.test.js tests/validator.test.js --verbose",
    "test:integration": "jest tests/app.test.js --verbose",
    "test:performance": "jest tests/performance.test.js --verbose",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 70
      }
    }
  }
}
